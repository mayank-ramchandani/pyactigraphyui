# Frontend
VITE_API_BASE_URL=http://localhost:8000/
VITE_APP_VERSION=local-dev
VITE_GITHUB_REPOSITORY_URL=https://github.com/mayank-ramchandani/pyactigraphyui
VITE_GITHUB_DOCS_URL=https://github.com/mayank-ramchandani/pyactigraphyui/tree/main/docs
VITE_ENABLE_AUTH_RUNS=false

# Backend
APP_VERSION=local-dev
GIT_COMMIT=unknown
# Local default only. In Azure, mount an Azure Files share and use its path,
# for example /data/actigraphy-ui; setting this value does not mount storage.
APP_DATA_DIR=/tmp/actigraphy-ui-data
CORS_ALLOW_ORIGINS=http://localhost:5173
EXPOSE_SERVER_ERROR_DETAILS=true
GT3X_STREAM_CHUNK_SECONDS=300
GT3X_PROGRESS_EVENT_INTERVAL=100000
GT3X_DEDUPE_WINDOW_SECONDS=300
GT3X_ISM_FILL_CHUNK_SECONDS=300
GT3X_LIGHT_EPOCH_PERIOD=30
ANALYSIS_JOB_MAX_WORKERS=1
ANALYSIS_JOB_TTL_SECONDS=21600
